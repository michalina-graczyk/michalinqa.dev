---
import heroImage from "@assets/images/hero.png";
import { Image } from "astro:assets";
import Button from "@components/ui/Button.astro";
import { getLangFromUrl, useTranslations } from "@i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section
  data-testid="hero"
  class="flex min-h-dvh flex-col-reverse items-center justify-center text-center lg:flex-row"
>
  <div class="mb-10 flex flex-col items-center lg:mb-0 lg:w-1/2">
    <div class="max-w-2xl">
      <h1
        class="mb-10 font-monospace text-3xl text-black [text-wrap:balance] dark:text-white lg:text-5xl"
        set:html={t('home.hero.title')}
      />
    </div>
    <div class="mb-10">
      <Button
        style={"secondary"}
        size={"lg"}
        class={"flex hero-cta"}
        name="see how I can help"
        href="#about"
      >
        {t('home.hero.cta')}
      </Button>
    </div>
  </div>
  <div
    data-testid="hero-img"
    class="mb-10 flex w-1/2 items-center justify-center"
  >
    <Image
      src={heroImage}
      alt="Coding girl"
      layout="constrained"
      width={600}
      priority
      class="max-w-[600px] w-full h-auto"
    />
  </div>
</section>

<script>
  import { trackClick, TrackingEvents } from "@lib/tracking";

  trackClick(".hero-cta", TrackingEvents.HERO_CTA_CLICKED);
</script>
