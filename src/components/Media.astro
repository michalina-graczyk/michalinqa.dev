---
import { Icon } from "astro-icon/components";
import SectionTitle from "@components/ui/SectionTitle.astro";
import cvData from "@data/cv.json";

const talks = cvData.talks ?? [];
---

{
  talks.length > 0 && (
    <section
      data-testid="media"
      id="media"
      class="mb-10 flex flex-col items-center justify-center lg:mb-0 lg:min-h-[50vh]"
    >
      <SectionTitle>Wystąpienia i media</SectionTitle>
      <div class="flex w-full flex-col gap-6 md:flex-row md:gap-8">
        {talks.map((talk) => (
          <article class="flex-1 rounded-xl bg-white p-6 shadow-lg dark:bg-gray-800 dark:shadow-orange/20">
            <p class="text-sm font-semibold uppercase tracking-wide text-orange">
              {talk.show}
              {talk.episode ? ` • ${talk.episode}` : ""}
            </p>
            <h3 class="mt-1 text-lg font-bold text-black dark:text-white">
              {talk.title}
            </h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-400">
              {talk.date}
              {talk.host ? ` • ${talk.host}` : ""}
            </p>
            {talk.summary && (
              <p class="mt-3 text-black dark:text-white">{talk.summary}</p>
            )}
            <div class="mt-4 flex flex-wrap gap-4">
              {talk.links.map((link) => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center text-black hover:text-orange dark:text-white dark:hover:text-orange"
                >
                  <Icon class="h-5 w-5 mr-1" name={link.icon} />
                  <span>{link.label}</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>
  )
}
