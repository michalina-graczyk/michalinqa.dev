---
import SectionTitle from "@components/ui/SectionTitle.astro";

const testimonials = [
  {
    name: "Ania",
    role: "QA Engineer",
    company: null,
    linkedIn: null,
    category: "mentoring",
    quote:
      "Thanks to our sessions, I demystified AI in software testing, understood AI architecture like agents and skills, and learned how to boost the efficiency of a modern tester. Every single session is 100% concrete, packed with deep knowledge, and focused entirely on practice.",
  },
  {
    name: "Patryk Andrzejewski",
    role: "Product Engineer",
    company: "Saleor Commerce",
    linkedIn: "https://www.linkedin.com/in/patryk-andrzejewski/",
    category: "collaboration",
    quote:
      "She took ownership of our end-to-end software quality in a way that made everyone feel more confident about what we were shipping. She's professional, experienced, and honestly just great to work with.",
  },
  {
    name: "Gabriela Salamon",
    role: "People & Culture",
    company: "Saleor Commerce",
    linkedIn: "https://www.linkedin.com/in/gabrielasalamon/",
    category: "collaboration",
    quote:
      "Michalina has been an incredible support to every team member - always approachable, always encouraging, and deeply committed to everyone's success.",
  },
];
---

<section
  data-testid="social-proof"
  id="social-proof"
  class="w-full py-16 lg:py-24"
>
  <div class="mx-auto w-full max-w-6xl px-4">
    <SectionTitle>Co mówią inni</SectionTitle>

    <div class="flex w-full flex-col gap-6 md:flex-row md:gap-8">
      {
        testimonials.map((t) => (
          <article
            data-testid="social-proof-testimonial"
            class="relative flex-1 rounded-xl bg-white p-6 shadow-lg dark:bg-gray-800 dark:shadow-orange/20"
          >
            <span
              class:list={[
                "absolute right-4 top-4 inline-flex items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs font-medium",
                t.category === "mentoring"
                  ? "border-orange/30 bg-orange/10 text-orange dark:bg-orange/20"
                  : "border-gray-300 bg-gray-100 text-gray-600 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-300",
              ]}
            >
              {t.category === "mentoring" ? "🎓 Mentoring" : "🤝 Collaboration"}
            </span>
            <blockquote class="mb-4 mt-4 italic text-black dark:text-white">
              "{t.quote}"
            </blockquote>
            <footer class="text-sm">
              {t.linkedIn ? (
                <a
                  href={t.linkedIn}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="font-semibold text-orange hover:underline"
                >
                  {t.name}
                </a>
              ) : (
                <span class="font-semibold text-orange">{t.name}</span>
              )}
              <p class="text-gray-600 dark:text-gray-400">
                {t.role}
                {t.company ? `, ${t.company}` : ""}
              </p>
            </footer>
          </article>
        ))
      }
    </div>
  </div>
</section>
